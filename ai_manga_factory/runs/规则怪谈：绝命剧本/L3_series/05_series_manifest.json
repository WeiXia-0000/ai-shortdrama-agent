{
  "schema_version": "1.1",
  "layout": "layered",
  "series_title": "规则怪谈：绝命剧本",
  "folders": "L0_setup → L1_season → L2_spine → L3_series → L4_episodes（文件名带序号前缀）",
  "how_to_read": "按文件夹层级 L0→L4 与文件名序号阅读；reading_order 的 step 为建议顺序。depends_on 为上游依赖。",
  "reading_order": [
    {
      "step": 1,
      "layer": "L0",
      "title": "聚合 setup",
      "file": "L0_setup/01_series_setup.json",
      "depends_on": [],
      "one_line": "入口汇总：市场、概念、评审等"
    },
    {
      "step": 2,
      "layer": "L0",
      "title": "选定概念",
      "file": "L0_setup/02_episode_pitch.json",
      "depends_on": [
        "L0_setup/01_series_setup.json"
      ],
      "one_line": "被选中概念卡片"
    },
    {
      "step": 3,
      "layer": "L1",
      "title": "整季主线",
      "file": "L1_season/01_season_mainline.json",
      "depends_on": [
        "L0_setup/02_episode_pitch.json"
      ],
      "one_line": "阶段目标与主线方向"
    },
    {
      "step": 4,
      "layer": "L1",
      "title": "人物成长",
      "file": "L1_season/02_character_growth.json",
      "depends_on": [
        "L1_season/01_season_mainline.json"
      ],
      "one_line": "主角/配角/团队弧线"
    },
    {
      "step": 5,
      "layer": "L1",
      "title": "世界揭示",
      "file": "L1_season/03_world_reveal_pacing.json",
      "depends_on": [
        "L1_season/01_season_mainline.json"
      ],
      "one_line": "认知层与机制揭示节奏"
    },
    {
      "step": 6,
      "layer": "L2",
      "title": "耦合对齐",
      "file": "L2_spine/01_coupling_map.json",
      "depends_on": [
        "L1_season/02_character_growth.json",
        "L1_season/03_world_reveal_pacing.json"
      ],
      "one_line": "人物线与世界线双向因果"
    },
    {
      "step": 7,
      "layer": "L2",
      "title": "系列骨架",
      "file": "L2_spine/02_series_spine.json",
      "depends_on": [
        "L2_spine/01_coupling_map.json"
      ],
      "one_line": "全作 spine"
    },
    {
      "step": 8,
      "layer": "L2",
      "title": "承重锚点",
      "file": "L2_spine/03_anchor_beats.json",
      "depends_on": [
        "L2_spine/02_series_spine.json"
      ],
      "one_line": "关键转折点"
    },
    {
      "step": 9,
      "layer": "L3",
      "title": "分集大纲",
      "file": "L3_series/01_series_outline.json",
      "depends_on": [
        "L2_spine/03_anchor_beats.json"
      ],
      "one_line": "episode_list + overall_arc"
    },
    {
      "step": 10,
      "layer": "L3",
      "title": "大纲评审",
      "file": "L3_series/01b_outline_review.json",
      "depends_on": [
        "L3_series/01_series_outline.json"
      ],
      "one_line": "题材/市场/节奏/转折评分与改写建议"
    },
    {
      "step": 11,
      "layer": "L3",
      "title": "角色圣经",
      "file": "L3_series/02_character_bible.json",
      "depends_on": [
        "L3_series/01_series_outline.json",
        "L3_series/01b_outline_review.json"
      ],
      "one_line": "外观锁与 Seedance 肖像"
    },
    {
      "step": 12,
      "layer": "L3",
      "title": "系列记忆",
      "file": "L3_series/03_series_memory.json",
      "depends_on": [
        "L3_series/01_series_outline.json"
      ],
      "one_line": "跨集记忆；batch 更新"
    },
    {
      "step": 13,
      "layer": "L3",
      "title": "批次汇总",
      "file": "L3_series/04_episode_batch.json",
      "depends_on": [
        "L3_series/03_series_memory.json"
      ],
      "one_line": "已生成分集 package 列表"
    },
    {
      "step": 14,
      "layer": "L3",
      "title": "阅读导航",
      "file": "L3_series/05_series_manifest.json",
      "depends_on": [
        "L3_series/04_episode_batch.json"
      ],
      "one_line": "本文件：顺序与依赖说明"
    }
  ],
  "episode_pipeline": {
    "folder": "L4_episodes/<剧名>_第NNN集/",
    "order": [
      "01_episode_function.json",
      "02_plot.json",
      "03_script.json",
      "04_storyboard.json",
      "05_creative_scorecard.json",
      "06_package.json"
    ],
    "one_line": "单集内：功能卡 → 节拍 → 剧本 → 分镜；最后一项为整集 package。"
  }
}